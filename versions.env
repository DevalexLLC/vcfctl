# Single source of truth for all pinned versions.
# Read by the Makefile and GitHub Actions workflows, passed to docker build as --build-arg.

# Broadcom VCF CLI release (packages.broadcom.com/artifactory/vcf-distro/vcf-cli/)
VCF_CLI_VERSION=9.0.2

# Broadcom VCF CLI plugin bundle (vcf-distro/vcf-cli-plugins/). Versioned independently
# from the CLI — as of 2026-07 only v9.0.0 has been published.
VCF_PLUGIN_BUNDLE_VERSION=9.0.0

# kubectl. Pinned to a minor that covers VCF 9.0 VKr Kubernetes versions within the
# kubectl +/-1 minor skew policy (1.33 talks to 1.32-1.34 API servers).
KUBECTL_VERSION=1.33.13
